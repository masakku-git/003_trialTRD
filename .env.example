# Anthropic API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Futu OpenD connection
FUTU_HOST=127.0.0.1
FUTU_PORT=11111
FUTU_TRADE_PWD=your_trade_password_here
FUTU_TRADE_ENV=SIMULATE   # SIMULATE or REAL

# Account info
FUTU_ACCOUNT_ID=your_account_id_here

# Trading params
MAX_POSITION_SIZE=100000   # JPY per position
MAX_POSITIONS=5
RISK_PER_TRADE=0.02        # 2% of portfolio per trade

# Paths
DB_PATH=/home/trading/bot/db/trading.db
WATCHLIST_PATH=/home/trading/bot/data/watchlist.json
LOG_DIR=/home/trading/bot/logs
